# ========= PDF =========
# Geração simples de PDF usando reportlab
from reportlab.lib.pagesizes import A4
from reportlab.pdfgen import canvas
from reportlab.lib.units import mm
from reportlab.lib.utils import simpleSplit

def _pdf_wrap_text(c: canvas.Canvas, text: str, x: float, y: float, max_width: float, line_height: float, max_lines: int = 120):
    """Desenha texto com quebra automática dentro de max_width (em pontos). Retorna a nova coordenada y."""
    # reportlab não quebra linhas automaticamente com drawString; usamos simpleSplit.
    # Atenção: y decresce conforme escrevemos (origem no canto inferior).
    if not text:
        return y
    # simpleSplit usa a font atual setada em canvas
    lines = simpleSplit(text, c._fontname, c._fontsize, max_width)
    written = 0
    for ln in lines:
        if written >= max_lines:
            c.drawString(x, y, "…")
            y -= line_height
            break
        c.drawString(x, y, ln)
        y -= line_height
        written += 1
        if y < 20 * mm:  # margem inferior -> cria nova página
            c.showPage()
            c.setFont("Helvetica", 10)
            y = 285 * mm
    return y

def _build_pdf(person: str, news_blocks: list[tuple[int, str, str]], org_blocks: list[tuple[int, str, str]], out_path_pdf: str):
    """
    Gera um PDF simples:
      - news_blocks: lista de tuples (idx, url, texto)
      - org_blocks:  lista de tuples (idx, url, texto)
    """
    os.makedirs(os.path.dirname(out_path_pdf), exist_ok=True)
    c = canvas.Canvas(out_path_pdf, pagesize=A4)
    width, height = A4

    # Cabeçalho
    margin_x = 18 * mm
    y = height - 18 * mm

    c.setFont("Helvetica-Bold", 14)
    c.drawString(margin_x, y, f"Buscador — Relatório por pessoa")
    y -= 7 * mm

    c.setFont("Helvetica", 11)
    stamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.drawString(margin_x, y, f"Pessoa: {person}   |   Gerado em: {stamp}")
    y -= 10 * mm

    max_width = width - 2 * margin_x
    line_h = 4.7 * mm

    # Notícias
    c.setFont("Helvetica-Bold", 12)
    c.drawString(margin_x, y, "Notícias (top):")
    y -= 6 * mm
    c.setFont("Helvetica", 10)
    if not news_blocks:
        y = _pdf_wrap_text(c, "Nenhuma notícia relevante encontrada.", margin_x, y, max_width, line_h)
        y -= 3 * mm
    else:
        for idx, url, txt in news_blocks:
            y = _pdf_wrap_text(c, f"Notícia {idx} — URL: {url}", margin_x, y, max_width, line_h)
            y = _pdf_wrap_text(c, txt or "(sem conteúdo extraído)", margin_x + 4 * mm, y, max_width - 4 * mm, line_h)
            y -= 3 * mm

    # Orgânicos
    c.setFont("Helvetica-Bold", 12)
    y = y - 3 * mm if y > 28 * mm else (c.showPage() or (285 * mm))
    if isinstance(y, tuple):  # caso raro do short-circuit acima
        c.setFont("Helvetica-Bold", 12)
        y = 285 * mm
    c.drawString(margin_x, y, "Resultados orgânicos (top):")
    y -= 6 * mm
    c.setFont("Helvetica", 10)
    if not org_blocks:
        y = _pdf_wrap_text(c, "Nenhum resultado orgânico extraído.", margin_x, y, max_width, line_h)
    else:
        for idx, url, txt in org_blocks:
            y = _pdf_wrap_text(c, f"Link {idx} — URL: {url}", margin_x, y, max_width, line_h)
            y = _pdf_wrap_text(c, txt or "(sem conteúdo extraído)", margin_x + 4 * mm, y, max_width - 4 * mm, line_h)
            y -= 3 * mm

    c.showPage()
    c.save()

# ========= helpers =========
def _strip_accents_lower(s: str) -> str:
    if not s:
        return ""
    return "".join(ch for ch in unicodedata.normalize("NFD", s.lower()) if unicodedata.category(ch) != "Mn")

def _name_variants(person: str) -> list[str]:
    """
    Gera variantes tolerantes do nome:
      - original
      - sem acentos
      - troca s↔z em 'lu(s|z)' quando aplicável (caso comum no PT-BR)
      - sem aspas supérfluas
    """
    base = person.strip().strip('"').strip("'")
    out = [base]

    # sem acentos
    noacc = _strip_accents_lower(base)
    # mantemos caixa original em uma variante também
    out.append(noacc)

    # heurística "luis ↔ luiz" (somente quando bate exato um token)
    tokens = base.split()
    lower_tokens = [t.lower() for t in tokens]
    if "luis" in lower_tokens:
        t2 = [("luiz" if t.lower() == "luis" else t) for t in tokens]
        out.append(" ".join(t2))
    if "luiz" in lower_tokens:
        t2 = [("luis" if t.lower() == "luiz" else t) for t in tokens]
        out.append(" ".join(t2))

    # sem acentos preservando caixa aproximada
    out.append(unicodedata.normalize("NFKD", base).encode("ASCII", "ignore").decode("ASCII"))

    # remover duplicatas mantendo ordem
    seen, dedup = set(), []
    for v in out:
        if v and v not in seen:
            seen.add(v)
            dedup.append(v)
    return dedup

class BuscadorWorker(threading.Thread):
    def __init__(
        self,
        names,
        out_dir,
        log_q,
        progress_cb,
        done_cb,
        stop_event,
        sleep_between=0.6,
        n_top=3,
        include_news=True,
        include_org=True,
        build_index_csv=False,
        index_rows_acc=None,
        router=None,
    ):
        super().__init__(daemon=True)
        self.settings = load_settings()  # para ler filters/export_pdf
        self.names = names
        self.out_dir = out_dir
        self.log_q = log_q
        self.progress_cb = progress_cb
        self.done_cb = done_cb
        self.stop_event = stop_event
        self.sleep_between = sleep_between
        self.n_top = n_top
        self.include_news = include_news
        self.include_org = include_org
        self.build_index_csv = build_index_csv
        self.index_rows_acc = index_rows_acc if index_rows_acc is not None else []
        self.router = router or QuotaAwareRouter()

    def log(self, msg: str):
        self.log_q.put(msg)

    def _extract_many(self, urls: list[str], label: str) -> list[tuple[int, str, str]]:
        """Extrai texto de uma lista de URLs e devolve [(i, url, texto_extraido)]."""
        blocks = []
        for i, u in enumerate(urls, 1):
            if self.stop_event.is_set():
                break
            self.log(f"    - Extraindo {label} {i}: {u}")
            try:
                txt = extract_main_text(u)
            except Exception as e:
                txt = ""
                self.log(f"      ⚠ Falha ao extrair: {e}")
            blocks.append((i, u, txt))
            time.sleep(self.sleep_between)
        return blocks

    def _search_news_with_variants(self, person: str) -> list[str]:
        """Tenta coletar notícias para a pessoa usando variantes do nome até preencher n_top."""
        news_urls: list[str] = []
        if not (self.include_news and self.router):
            return news_urls

        tried = []
        for variant in _name_variants(person):
            if self.stop_event.is_set():
                break
            if variant in tried:
                continue
            tried.append(variant)

            try:
                nres = self.router.search_news_free(variant, user_id="tk", max_n=self.n_top * 2)
                payload = nres.get("response", {})
                found = pick_news_urls(payload, n=self.n_top - len(news_urls))
                provider = nres.get("provider", "none")
                self.log(f"  • Notícias via {provider} (variante: {variant}): {len(found)}")
                for u in found:
                    if u not in news_urls:
                        news_urls.append(u)
                if len(news_urls) >= self.n_top:
                    break
            except Exception as e:
                self.log(f"  ⚠ Erro na busca de notícias (variante '{variant}'): {e}")

        return news_urls[: self.n_top]

    def run(self):
        total = len(self.names)
        completed = 0
        try:
            for name in self.names:
                if self.stop_event.is_set():
                    self.log("➡ Execução cancelada pelo usuário.")
                    break

                name_disp = name.strip()
                if not name_disp:
                    completed += 1
                    self.progress_cb(completed, total)
                    continue

                filters = (self.settings or {}).get("filters", {}) or {}
                cpf = (filters.get("cpf") or "").strip()
                city = (filters.get("city") or "").strip()
                uf   = (filters.get("uf") or "").strip()
                export_pdf = bool((self.settings or {}).get("export_pdf", False))

                # Ajusta a query orgânica com “hints”
                query_for_org = apply_hints_to_query(name_disp, cpf=cpf, city=city, uf=uf)

                self.log(f"\n🔎 Buscando: {name_disp}")

                news_urls, org_urls = [], []

                # 1) Orgânicos (pagos com roteador de cotas)
                if self.include_org and self.router:
                    try:
                        result = self.router.search(query_for_org, user_id="tk")
                        payload = result["response"]
                        prov = result.get("provider", "desconhecido")
                        org_urls = pick_organic_urls(payload, n=self.n_top)
                        self.log(f"  • Orgânico via {prov}: {len(org_urls)}")
                    except Exception as e:
                        self.log(f"  ⚠ Erro na busca orgânica: {e}")

                # 2) Notícias gratuitas (Google RSS → fallback GDELT), com variantes do nome
                if self.include_news and self.router:
                    news_urls = self._search_news_with_variants(name_disp)

                # CSV-índice (opcional)
                if self.build_index_csv:
                    for i, u in enumerate(news_urls, 1):
                        self.index_rows_acc.append([name_disp, "noticia", i, u])
                    for i, u in enumerate(org_urls, 1):
                        self.index_rows_acc.append([name_disp, "organico", i, u])

                # ===== Monta saída TXT e material para PDF =====
                blocks_txt = [f"# Buscador rápido — consulta: {name_disp}\n"]

                # Notícias
                news_blocks = []
                if news_urls:
                    blocks_txt.append(f"## Notícias (top {self.n_top})\n")
                    news_blocks = self._extract_many(news_urls, label="notícia")
                    for (i, u, txt) in news_blocks:
                        blocks_txt.append(f"### Notícia {i}\nURL: {u}\n\n{txt}\n")

                # Orgânicos
                org_blocks = []
                if org_urls and not self.stop_event.is_set():
                    blocks_txt.append(f"## Resultados orgânicos (top {self.n_top})\n")
                    org_blocks = self._extract_many(org_urls, label="link")
                    for (i, u, txt) in org_blocks:
                        blocks_txt.append(f"### Link {i}\nURL: {u}\n\n{txt}\n")

                # Texto concatenado único (útil para grep/local search)
                concatenado = [f"# Texto concatenado — {name_disp}\n"]
                if not self.stop_event.is_set():
                    for _, _, txt in news_blocks + org_blocks:
                        if txt:
                            concatenado.append(txt)
                        time.sleep(self.sleep_between)

                header_text = "\n".join(blocks_txt).strip()
                full_concat = "\n\n".join(concatenado).strip()

                stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
                base = f"{safe_filename(name_disp)}_{stamp}"
                txt_path = os.path.join(self.out_dir, base + ".txt")
                pdf_path = os.path.join(self.out_dir, base + ".pdf")

                # Salva TXT
                try:
                    with open(txt_path, "w", encoding="utf-8") as f:
                        f.write(header_text)
                        f.write("\n\n" + "=" * 80 + "\n\n")
                        f.write(full_concat)
                    self.log(f"  ✅ TXT salvo: {txt_path}")
                except Exception as e:
                    self.log(f"  ⚠ Falha ao salvar TXT: {e}")

                # Salva PDF (se habilitado)
                if export_pdf:
                    try:
                        _build_pdf(
                            person=name_disp,
                            news_blocks=news_blocks,
                            org_blocks=org_blocks,
                            out_path_pdf=pdf_path,
                        )
                        self.log(f"  ✅ PDF salvo: {pdf_path}")
                    except Exception as e:
                        self.log(f"  ⚠ Falha ao gerar PDF: {e}")

                # (Opcional) HTML — se você já tiver um exporter
                if save_html_report is not None:
                    try:
                        html_path = os.path.join(self.out_dir, base + ".html")
                        save_html_report(
                            person=name_disp,
                            news_blocks=news_blocks,
                            org_blocks=org_blocks,
                            out_path_html=html_path,
                        )
                        self.log(f"  ✅ HTML salvo: {html_path}")
                    except Exception as e:
                        self.log(f"  ⚠ Falha ao gerar HTML: {e}")

                completed += 1
                self.progress_cb(completed, total)

        finally:
            self.done_cb()
            self.log("🏁 Busca concluída.")